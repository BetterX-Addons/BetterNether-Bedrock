{
  "format_version": "1.26.0",
  "minecraft:entity": {
    "description": {
      "identifier": "betternether:hydrogen_jellyfish",
      "spawn_category": "creature",
      "is_spawnable": true,
      "is_summonable": true,
      "runtime_identifier": "minecraft:blaze"
    },
    "component_groups": {
      "betternether:explode": {
        "minecraft:explode": {
          "fuse_lit": true,
          "power": 6,
          "causes_fire": false,
          "breaks_blocks": true
        }
      }
    },
    "components": {
      "minecraft:physics": {},
      "minecraft:health": {
        "value": 1,
        "max": 1
      },
      "minecraft:type_family": {
        "family": [
          "hydrogen_jellyfish",
          "mob"
        ]
      },
      "minecraft:collision_box": {
        "width": 1.7,
        "height": 5.9
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava"
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:damage_sensor": {
        "triggers": [
          {
            "cause": "fall",
            "deals_damage": "no"
          },
          {
            "on_damage": {
              "filters": {
                "test": "has_damage",
                "subject": "self",
                "value": "fatal"
              },
              "event": "betternether:explode"
            },
            "deals_damage": "no"
          }
        ]
      },
      "minecraft:conditional_bandwidth_optimization": {},
      "minecraft:is_hidden_when_invisible": {},
      "minecraft:renders_when_invisible": {},
      "minecraft:despawn": {
        "despawn_from_distance": {}
      },
      "minecraft:body_rotation_always_follows_head": {},
      // fly
      "minecraft:can_fly": {},
      "minecraft:behavior.random_fly": {
        "avoid_damage_blocks": true,
        "can_land_on_trees": true,
        "xz_dist": 10,
        "y_dist": 7,
        "y_offset": 0
      },
      "minecraft:movement.fly": {},
      "minecraft:behavior.float": {},
      "minecraft:navigation.fly": {},
        "minecraft:flying_speed": {
          "value": 0.1
        },
        "minecraft:behavior.float_wander": {
          "priority": 7,
          "must_reach": true,
          "random_reselect": true,
          "navigate_around_surface": true,
          "additional_collision_buffer": true,
          "allow_navigating_through_liquids": false,
          "use_home_position_restriction": true,
          "surface_xz_dist": 16,
          "surface_y_dist": 16,
          "float_duration": [
            2.0,
            7.0
          ]
        }
    },
    "events": {
      "betternether:explode": {
        "add": {
          "component_groups": [
            "betternether:explode"
          ]
        }
      }
    }
  }
}