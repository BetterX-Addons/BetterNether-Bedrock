{
  "format_version": "1.26.0",
  "minecraft:entity": {
    "description": {
      "identifier": "betternether:hydrogen_jellyfish",
      "spawn_category": "creature",
      "is_spawnable": true,
      "is_summonable": true,
      "runtime_identifier": "minecraft:blaze"
    },
    "component_groups": {
      "betternether:big": {
        "minecraft:scale": {
          "value": 1
        }
      },
      "betternether:medium": {
        "minecraft:scale": {
          "value": 0.9
        }
      },
      "betternether:small": {
        "minecraft:scale": {
          "value": 0.8
        }
      },
      "betternether:explode": {
        "minecraft:explode": {
          "fuse_lit": true,
          "power": 6,
          "causes_fire": false,
          "breaks_blocks": true
        }
      }
    },
    "components": {
      "minecraft:physics": {
        "has_collision": true,
        "has_gravity": false
      },
      "minecraft:health": {
        "value": 1,
        "max": 1
      },
      "minecraft:type_family": {
        "family": [
          "hydrogen_jellyfish",
          "mob"
        ]
      },
      "minecraft:collision_box": {
        "width": 1.7,
        "height": 5.9
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava"
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:damage_sensor": {
        "triggers": [
          {
            "cause": "fall",
            "deals_damage": "no"
          },
          {
            "on_damage": {
              "filters": {
                "test": "has_damage",
                "subject": "self",
                "value": "fatal"
              },
              "event": "betternether:explode"
            },
            "deals_damage": "no"
          }
        ]
      },
      "minecraft:conditional_bandwidth_optimization": {},
      "minecraft:is_hidden_when_invisible": {},
      "minecraft:renders_when_invisible": {},
      "minecraft:despawn": {
        "despawn_from_distance": {}
      },
      "minecraft:body_rotation_always_follows_head": {},
      // fly
      "minecraft:can_fly": {},
      "minecraft:behavior.random_fly": {},
      "minecraft:behavior.float": {},
      "minecraft:movement": {
        "value": 0.02
      },
      "minecraft:flying_speed": {
        "value": 0.05
      },
      "minecraft:movement.hover": {},
      "minecraft:navigation.hover": {
        "can_path_over_water": true,
        "avoid_damage_blocks": true,
        "can_path_from_air": true,
        "avoid_water": true
      },
      "minecraft:behavior.random_hover": {
				"priority": 12,
				"xz_dist": 8,
				"y_dist": 8,
				"y_offset": -1,
				"interval": 1,
				"hover_height": [
					1,
					10
				]
			},
      "minecraft:behavior.float_wander": {}
    },
    "events": {
      "minecraft:entity_spawned": {
        "randomize": [
          {
            "weight": 1,
            "add": {
              "component_groups": [
                "betternether:big"
              ]
            }
          },
          {
            "weight": 2,
            "add": {
              "component_groups": [
                "betternether:medium"
              ]
            }
          },
          {
            "weight": 3,
            "add": {
              "component_groups": [
                "betternether:small"
              ]
            }
          }
        ]
      },
      "betternether:explode": {
        "add": {
          "component_groups": [
            "betternether:explode"
          ]
        }
      }
    }
  }
}